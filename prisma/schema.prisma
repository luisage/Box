// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

// ============================================================
// schema.prisma — Sistema de Entrenador de Box
// Base de datos: PostgreSQL
// ORM: Prisma
// ============================================================

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Nivel {
  PRINCIPIANTE
  INTERMEDIO
  AVANZADO
  COMPETIDOR
}

enum Turno {
  MANANA
  TARDE
  NOCHE
}

enum EstadoAlumno {
  ACTIVO
  INACTIVO
  BAJA
}

enum CategoriaPeso {
  MINIMOSMO    // hasta 47.6 kg
  MOSCA        // hasta 50.8 kg
  SUPERMOSCA   // hasta 52.2 kg
  GALLO        // hasta 53.5 kg
  SUPERGALLO   // hasta 55.3 kg
  PLUMA        // hasta 57.2 kg
  SUPERPLUMA   // hasta 59 kg
  LIGERO       // hasta 61.2 kg
  SUPERLIGERO  // hasta 63.5 kg
  WELTER       // hasta 66.7 kg
  SUPERWELTER  // hasta 69.9 kg
  MEDIANO      // hasta 72.6 kg
  SUPERMEDIANO // hasta 76.2 kg
  SEMIPESADO   // hasta 79.4 kg
  CRUCERO      // hasta 90.7 kg
  PESADO       // más de 90.7 kg
}

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
  TARJETA
}

enum EstadoPago {
  PAGADO
  ABONO
  PENDIENTE
  VENCIDO
}

enum EstadoResena {
  VISIBLE
  OCULTA
  PENDIENTE
}

enum ResultadoCombate {
  VICTORIA
  DERROTA
  EMPATE
  NO_CONTEST
}

// ============================================================
// TABLA: Alumno
// ============================================================

model Alumno {
  id                  Int           @id @default(autoincrement())
  nombre              String        @db.VarChar(100)
  apellido            String        @db.VarChar(100)
  fechaNacimiento     DateTime      @map("fecha_nacimiento") @db.Date
  telefono            String?       @db.VarChar(20)
  fotoUrl             String?       @map("foto_url") @db.VarChar(500)

  // Datos deportivos
  nivel               Nivel         @default(PRINCIPIANTE)
  pesoKg              Int?     
  categoriaPeso       CategoriaPeso?  @map("categoria_peso")
  turno               Turno         @default(TARDE)
  estado              EstadoAlumno  @default(ACTIVO)
  fechaInscripcion    DateTime      @map("fecha_inscripcion") @default(now()) @db.Date

  // Datos de pago
  mensualidad         Decimal       @db.Decimal(8, 2)
  diaLimitePago       Int           @map("dia_limite_pago") @default(5)
  descuento           Int       @default(0)

  // Timestamps
  creadoEn            DateTime      @map("creado_en") @default(now())
  actualizadoEn       DateTime      @map("actualizado_en") @updatedAt

  // Relaciones
  pagos               Pago[]
  asistencias         Asistencia[]
  progresos           ProgresoFisico[]
  combates            Combate[]
  
  @@map("alumnos")
}

// ============================================================
// TABLA: Pago
// ============================================================

model Pago {
  id                  Int           @id @default(autoincrement())
  alumnoId            Int           @map("alumno_id")
  fechaPago           DateTime      @map("fecha_pago") @default(now()) @db.Date
  monto               Int       
  metodoPago          MetodoPago    @map("metodo_pago") @default(EFECTIVO)
  mesCorrespondiente  String        @map("mes_correspondiente") @db.VarChar(7)  // formato: "2025-01"
  estadoPago          EstadoPago    @map("estado_pago") @default(PAGADO)
  notas               String?       @db.Text
  registradoPor       String?       @map("registrado_por") @db.VarChar(100)

  // Timestamps
  creadoEn            DateTime      @map("creado_en") @default(now())

  // Relaciones
  alumno              Alumno        @relation(fields: [alumnoId], references: [id], onDelete: Cascade)

  @@index([alumnoId])
  @@index([mesCorrespondiente])
  @@index([estadoPago])
  @@map("pagos")
}

// ============================================================
// TABLA: Asistencia
// ============================================================

model Asistencia {
  id                  Int           @id @default(autoincrement())
  alumnoId            Int           @map("alumno_id")
  fecha               DateTime      @default(now()) @db.Date
  horaEntrada         DateTime      @map("hora_entrada") @db.Time
  horaSalida          DateTime?     @map("hora_salida") @db.Time
  observacion         String?       @db.Text

  // Timestamps
  creadoEn            DateTime      @map("creado_en") @default(now())

  // Relaciones
  alumno              Alumno        @relation(fields: [alumnoId], references: [id], onDelete: Cascade)

  @@unique([alumnoId, fecha])
  @@index([alumnoId])
  @@index([fecha])
  @@map("asistencias")
}

// ============================================================
// TABLA: ProgresoFisico
// ============================================================

model ProgresoFisico {
  id                  Int           @id @default(autoincrement())
  alumnoId            Int           @map("alumno_id")
  fechaMedicion       DateTime      @map("fecha_medicion") @default(now()) @db.Date
  pesoKg              Decimal?      @map("peso_kg") @db.Decimal(5, 2)
  tallaCm             Decimal?      @map("talla_cm") @db.Decimal(5, 2)
  porcentajeGrasa     Decimal?      @map("porcentaje_grasa") @db.Decimal(4, 2)
  imc                 Decimal?      @db.Decimal(4, 2)  // calculado: peso / (talla_m^2)
  notas               String?       @db.Text

  // Timestamps
  creadoEn            DateTime      @map("creado_en") @default(now())

  // Relaciones
  alumno              Alumno        @relation(fields: [alumnoId], references: [id], onDelete: Cascade)

  @@index([alumnoId])
  @@index([fechaMedicion])
  @@map("progreso_fisico")
}

// ============================================================
// TABLA: Combate
// ============================================================

model Combate {
  id                  Int               @id @default(autoincrement())
  alumnoId            Int               @map("alumno_id")
  fecha               DateTime          @db.Date
  rival               String            @db.VarChar(150)
  resultado           ResultadoCombate
  categoria           String?           @db.VarChar(50)
  evento              String?           @db.VarChar(200)
  lugar               String?           @db.VarChar(200)
  rounds              Int?
  notas               String?           @db.Text

  // Timestamps
  creadoEn            DateTime          @map("creado_en") @default(now())

  // Relaciones
  alumno              Alumno            @relation(fields: [alumnoId], references: [id], onDelete: Cascade)

  @@index([alumnoId])
  @@index([fecha])
  @@map("combates")
}

// ============================================================
// TABLA: Resena
// ============================================================

model Resena {
  id                  Int           @id @default(autoincrement())
  fecha               DateTime      @default(now())
  calificacion        Int           // 1 a 5 estrellas
  comentario          String        @db.Text
  estado              EstadoResena  @default(PENDIENTE)

  // Timestamps
  creadoEn            DateTime      @map("creado_en") @default(now())

  @@index([estado])
  @@map("resenas")
}

model User {
  id    Int     @id @default(autoincrement())
  usuario String?  @unique
  password String
  nombre  String?
  apellido  String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  USER
}

model Novedades {
  id          Int      @id @default(autoincrement())
  titulo      String    
  descripcion  String   
  vigencia     String?
  estatus        Boolean  @default(true)
}

model categoriaProducto {
  id          Int      @id @default(autoincrement())
  nombre      String    
  estatus        Boolean  @default(true)
}

model productos {
  id          Int      @id @default(autoincrement())
  nombre      String    
  descripcion  String   
  imagen     String?
  costo Int
  categoria  String
  estatus        Boolean  @default(true)
}

model imagenCarrusel {
  id          Int      @id @default(autoincrement())
  nombre      String?    
  url     String
  estatus        Boolean  @default(true)
}

model videos {
  id          Int      @id @default(autoincrement())
  nombre      String? 
  descripcion  String?   
  url     String
  publicId    String
  estatus        Boolean  @default(true)
  orden       Int      @default(0)
  creadoEn    DateTime @default(now())
}